export default "// ============================================================\n//  PROPOSAL -- review before promoting to data/standards/\n//  name epichlorohydrin   CAS 106-89-8   (epichlorohydrin)\n//  Tc<-PSRK Pc<-PSRK omega<-PSRK Tb<-WIKIDATA Hfg<-gap Psat<-AmbroseWalton(est) Cp<-GAP\n//  license     scalars + Psat = OPEN (CoolProp-MIT / corr-states); Cp/formation stripped for copyright -- student supplies\n//  status UNVERIFIED PROPOSAL   generated 2026-06-07 chemicals/thermo bulk\n// ============================================================\n\nname        epichlorohydrin;\nMW          92.5242;\nTc          610;\nPc          49.0008;\nomega       0.2562;\nTb          389.817;\n// (Antoine fit removed for copyright caution; corr-states estimate instead)\nvaporPressure { model AmbroseWalton; }\n// vaporPressure\n// {\n//     model    AmbroseWalton;\n// }\n\n// --- energy block: ESTIMATED (MIT-panel policy 2026-06-07), review before reaction-critical use ---\ngibbsFormation\n{\n    dHf_298   -180190;      // J/mol  ideal-gas [origin=estimated method=Joback uncertainty=~9kJ/mol]\n    dGf_298   -62920;      // J/mol  ideal-gas [Joback]\n    s_298     164.709;      // J/(mol*K) third-law [DERIVED: (dHf-dGf)/T + CODATA element S; ~25 J/mol/K; biased ~R*ln(sigma) for symmetric species]\n    phase     gas;\n}\nidealGasHeatCapacity   // [origin=estimated method=Joback-Cp uncertainty~3%, valid<=1000K]\n{\n    model         polynomial;\n    coefficients  (-19.869   0.4435   -0.0003661   1.241e-07);\n    Trange        (200  1000);\n}\n\n\n// Molecular group decomposition (the curation recipe this estimate was built\n// from).  Joback groups; re-run reproduces the estimate.  Method-keyed.\ngroups { joback ( { group CH2; count 1; } { group rCH2; count 1; } { group rCH; count 1; } { group Cl; count 1; } { group etherRing; count 1; } ); }\n\n// --- review status (machine-readable; data/proposed UNVERIFIED tier) ----------\n//  This file lives in data/proposed/ (NOT the verified data/standards/ tree).\n//  A student must REVIEW the values and PROMOTE it before they are trusted.\nprovenance\n{\n    status  \"UNVERIFIED ESTIMATE -- student-review pending (data/proposed tier)\";\n    review  { state pending; reviewer student; }\n}\n"