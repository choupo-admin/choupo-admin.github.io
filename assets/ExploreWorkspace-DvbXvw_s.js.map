export default "// HELD (Wave-2 REPLACE merge): grafts the prior standard's\n// formation/transport over CoolProp constants. NOT promotable\n// until its inherited gibbs is re-sourced clean. Per-file GO only.\n/*--------------------------------*- Choupo -*-----------------------*\\\n  Component: acetone  (C3H6O1, CAS 67-64-1)\n  PROPOSAL TIER -- UNVERIFIED.  Imported from CoolProp 7.2.0 (MIT);\n  pure-fluid properties from the published reference EOS below.\n  Reference EOS: Lemmon-JCED-2006\n  NOTE: formation properties (dHf, s_298) and group decompositions\n  are NOT provided by CoolProp -> omitted here (a gap, not fabricated).\n\\*---------------------------------------------------------------------------*/\n\nname        acetone;\nformula     C3H6O1;\nCAS         67-64-1;\n\nMW          58.0791;        // kg/kmol  [CoolProp]\nTc          508.1000;        // K        [CoolProp EOS]\nPc          46.92417;        // bar      [CoolProp EOS]\nomega       0.30710;        // [-]      [CoolProp EOS]\nTb          329.2249;        // K  normal boiling [CoolProp]\nHvapTb      29122.4;        // J/mol  at Tb     [CoolProp]\nVliq        7.4021e-05;        // m3/mol @298K     [CoolProp]\n\nvaporPressure\n{\n    model         Antoine;\n    // log10(Psat [bar]) = A - B / (T[K] + C)   -- fitted to CoolProp EOS\n    coefficients  (4.33219   1255.89   -39.0822);\n    Trange        (228.65  497.94);\n}\n\nidealGasHeatCapacity\n{\n    model         polynomial;\n    // Cp [J/(mol.K)] = a0 + a1 T + a2 T^2 + a3 T^3   -- fitted to CoolProp cp0\n    coefficients  (24.6394  0.170638  1.63755e-05  -5.0493e-08);\n    Trange        (200  1000);\n}\n\nliquidHeatCapacity\n{\n    model         polynomial;\n    // Cp_liq [J/(mol.K)]   -- fitted to CoolProp saturated-liquid cp\n    coefficients  (137.793  -0.238444  0.000672304  -7.52226e-08);\n    Trange        (254  329);\n}\n\nsublimation\n{\n    tripleT   178.5000;        // K   [CoolProp]\n    tripleP   2.3265;        // Pa  [CoolProp]\n    // Hfus / Hsub absent: CoolProp models no solid phase.  The\n    // sublimation curve stays undrawn until measured Hsub lands.\n}\n\n             gibbsFormation  -- [prior-standard] [prior-standard] (ideal-gas, 298 K)\n\\*---------------------------------------------------------------------------*/\n\nname        acetone;\nformula     C3H6O;\nCAS         67-64-1;\n\nMW          58.080;        // kg/kmol\nTc          508.10;        // K\nPc          47.01;         // bar\nomega       0.3070;        // [-]   acentric factor\nTb          329.22;        // K     normal boiling point\nHvapTb      29100;         // J/mol latent heat at Tb\nVliq        7.35e-5;       // m³/mol liquid molar volume at 25 °C (73.5 cm³/mol)\n\ngibbsFormation\n{\n    dHf_298   -217100.0;      // J/mol  -- ideal-gas reference\n    s_298     295.30;         // J/(mol·K) -- third-law absolute\n    phase     gas;            // ideal-gas Hf reference\n}\ngroups\n{\n    joback ( { group CH3; count 2; } { group ketone; count 1; } );\n    unifac ( { group CH3; count 1; } { group CH3CO; count 1; } );\n}\ndiffusionVolume  67.7;\n\nprovenance\n{\n    constants      \"CoolProp 7.2.0 -- Lemmon-JCED-2006\";\n    vaporPressure  \"Antoine fitted to CoolProp EOS saturation, AAD 0.63%\";\n    idealGasCp     \"polynomial fitted to CoolProp cp0, maxerr 2.83%\";\n    liquidCp       \"polynomial fitted to CoolProp sat-liquid cp, maxerr 0.00%\";\n    triplePoint    \"CoolProp reference EOS triple-point T,P\";\n    inherited      \"gibbs/groups/transport grafted from prior standard (orig. attrib. = excluded aggregators (see COOLPROP-REPLACE-MERGE.md) -> re-source pending); CoolProp supplies constants/VP/Cp/triple\";\n}\n"