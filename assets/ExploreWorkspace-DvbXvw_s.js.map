export default "/*---------------------------------------------------------------------------*\\\n  Component: compA  -- synthetic component for VLLE algorithm audit.\n  Antoine tuned so Psat ≈ 5 bar at 350 K (the \"very volatile\" component\n  that will preferentially go to vapour in the audit test).\n\\*---------------------------------------------------------------------------*/\n\nname        compA;\nformula     A;\nCAS         00-00-0;\n\nMW          30.0;\nTc          500.0;\nPc          50.0;\nomega       0.10;\nTb          320.0;\nHvapTb      28000;\nVliq        8.0e-5;\n\nvaporPressure\n{\n    model         Antoine;\n    coefficients  (4.0   1700.0   -30.0);   // log10 P_bar = A - B/(T + C); Psat(350) ≈ 5 bar\n    Trange        (300  400);\n}\n\nidealGasHeatCapacity\n{\n    model         polynomial;\n    coefficients  (80.0   0.0   0.0   0.0);\n    Trange        (200  500);\n}\n\nliquidHeatCapacity\n{\n    model         polynomial;\n    coefficients  (120.0);\n    Trange        (300  400);\n}\n"