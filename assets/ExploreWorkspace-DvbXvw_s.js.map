export default "// ============================================================\n//  PROPOSAL (SOLID) -- review before promoting to data/standards/\n//  name citricacid   CAS 77-92-9   (citric acid)   formula C6H8O7\n//  provenance  Hfs<-stripped  S0s<-default  Cp_solid<-gap (via chemicals/thermo)\n//  license     scalars+rho_p = facts; Cp = Lastovka (open estimate); formation = student supplies (cite primary)\n//  status UNVERIFIED PROPOSAL   generated 2026-06-07 solids ingestion\n// ============================================================\n\nname        citricacid;\nformula     C6H8O7;\nCAS         77-92-9;\nMW          192.124;        // kg/kmol\nrole        nonvolatile;\nsolid\n{\n    rho_p   1660;        // particle density [kg/m^3]\n}\n// gibbsFormation STRIPPED: dHf/s_298 below were from [excluded source] (excluded). Re-source from\n// CODATA Key Values / primary calorimetry + cite, then uncomment:\n// gibbsFormation\n// {\n//     dHf_298   FILL;   // value removed (excluded source); student supplies, cite primary\n//     s_298     FILL;   // value removed (excluded source); student supplies, cite primary\n//     phase     solid;\n// }\n\n// --- energy block: ESTIMATED (MIT-panel policy 2026-06-07), review before reaction-critical use ---\ngibbsFormation\n{\n    dHf_298   -1.37896e+06;      // J/mol  ideal-gas [origin=estimated method=Joback uncertainty=~9kJ/mol]\n    dGf_298   -1.16607e+06;      // J/mol  ideal-gas [Joback]\n    s_298     561.148;      // J/(mol*K) third-law [DERIVED: (dHf-dGf)/T + CODATA element S; ~25 J/mol/K; biased ~R*ln(sigma) for symmetric species]\n    phase     gas;\n}\nidealGasHeatCapacity   // [origin=estimated method=Joback-Cp uncertainty~3%, valid<=1000K]\n{\n    model         polynomial;\n    coefficients  (-7.948   0.886   -0.0007226   2.259e-07);\n    Trange        (200  1000);\n}\n\n\n// Molecular group decomposition (the curation recipe this estimate was built\n// from).  Joback groups; re-run reproduces the estimate.  Method-keyed.\ngroups { joback ( { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group acid; count 3; } ); }\n\n// --- review status (machine-readable; data/proposed UNVERIFIED tier) ----------\n//  This file lives in data/proposed/ (NOT the verified data/standards/ tree).\n//  A student must REVIEW the values and PROMOTE it before they are trusted.\nprovenance\n{\n    status  \"UNVERIFIED ESTIMATE -- student-review pending (data/proposed tier)\";\n    review  { state pending; reviewer student; }\n}\n"