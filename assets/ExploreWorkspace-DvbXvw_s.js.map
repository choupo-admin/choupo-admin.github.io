export default "// ============================================================\n//  PROPOSAL (SOLID) -- review before promoting to data/standards/\n//  name magnesiumhydroxide   CAS 1309-42-8   (magnesium hydroxide)   formula H2MgO2\n//  provenance  Hfs<-stripped  S0s<-stripped  Cp_solid<-JANAF (via chemicals/thermo)\n//  license     scalars+rho_p = facts; Cp = Lastovka (open estimate); formation = student supplies (cite primary)\n//  status UNVERIFIED PROPOSAL   generated 2026-06-07 solids ingestion\n// ============================================================\n\nname        magnesiumhydroxide;\nformula     H2MgO2;\nCAS         1309-42-8;\nMW          58.3197;        // kg/kmol\nrole        nonvolatile;\nsolid\n{\n    rho_p   2340;        // particle density [kg/m^3]\n}\n\n// --- review status (machine-readable; data/proposed UNVERIFIED tier) ----------\n//  This file lives in data/proposed/ (NOT the verified data/standards/ tree).\n//  A student must REVIEW the values and PROMOTE it before they are trusted.\nprovenance\n{\n    status  \"UNVERIFIED ESTIMATE -- student-review pending (data/proposed tier)\";\n    review  { state pending; reviewer student; }\n}\n"