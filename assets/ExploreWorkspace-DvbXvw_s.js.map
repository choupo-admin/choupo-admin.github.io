export default "// HELD (Wave-2 REPLACE merge): grafts the prior standard's\n// formation/transport over CoolProp constants. NOT promotable\n// until its inherited gibbs is re-sourced clean. Per-file GO only.\n/*--------------------------------*- Choupo -*-----------------------*\\\n  Component: nHexane  (C6H14, CAS 110-54-3)\n  PROPOSAL TIER -- UNVERIFIED.  Imported from CoolProp 7.2.0 (MIT);\n  pure-fluid properties from the published reference EOS below.\n  Reference EOS: Thol-FPE-2019-alkanes-hexane\n  NOTE: formation properties (dHf, s_298) and group decompositions\n  are NOT provided by CoolProp -> omitted here (a gap, not fabricated).\n\\*---------------------------------------------------------------------------*/\n\nname        nHexane;\nformula     C6H14;\nCAS         110-54-3;\n\nMW          86.1754;        // kg/kmol  [CoolProp]\nTc          507.8200;        // K        [CoolProp EOS]\nPc          30.44115;        // bar      [CoolProp EOS]\nomega       0.30032;        // [-]      [CoolProp EOS]\nTb          341.8656;        // K  normal boiling [CoolProp]\nHvapTb      28880.8;        // J/mol  at Tb     [CoolProp]\nVliq        1.3161e-04;        // m3/mol @298K     [CoolProp]\n\nvaporPressure\n{\n    model         Antoine;\n    // log10(Psat [bar]) = A - B / (T[K] + C)   -- fitted to CoolProp EOS\n    coefficients  (4.09237   1218.14   -43.8427);\n    Trange        (228.52  497.66);\n}\n\nidealGasHeatCapacity\n{\n    model         polynomial;\n    // Cp [J/(mol.K)] = a0 + a1 T + a2 T^2 + a3 T^3   -- fitted to CoolProp cp0\n    coefficients  (17.4615  0.468399  -0.000118263  -3.8772e-08);\n    Trange        (200  1000);\n}\n\nliquidHeatCapacity\n{\n    model         polynomial;\n    // Cp_liq [J/(mol.K)]   -- fitted to CoolProp saturated-liquid cp\n    coefficients  (224.1  -0.744366  0.00283717  -2.20806e-06);\n    Trange        (254  342);\n}\n\nsublimation\n{\n    tripleT   177.8300;        // K   [CoolProp]\n    tripleP   1.1890;        // Pa  [CoolProp]\n    // Hfus / Hsub absent: CoolProp models no solid phase.  The\n    // sublimation curve stays undrawn until measured Hsub lands.\n}\n\ngibbsFormation\n{\n    dHf_298   -167200.0;        // J/mol  -- ideal-gas reference\n    s_298     388.510;         // J/(mol·K)  -- third-law absolute\n    phase     gas;            // ideal-gas Hf reference ([prior-standard]/JANAF convention)\n}\n\nprovenance\n{\n    constants      \"CoolProp 7.2.0 -- Thol-FPE-2019-alkanes-hexane\";\n    vaporPressure  \"Antoine fitted to CoolProp EOS saturation, AAD 0.52%\";\n    idealGasCp     \"polynomial fitted to CoolProp cp0, maxerr 4.31%\";\n    liquidCp       \"polynomial fitted to CoolProp sat-liquid cp, maxerr 0.00%\";\n    triplePoint    \"CoolProp reference EOS triple-point T,P\";\n    inherited      \"gibbs/groups/transport grafted from prior standard (orig. attrib. = excluded aggregators (see COOLPROP-REPLACE-MERGE.md) -> re-source pending); CoolProp supplies constants/VP/Cp/triple\";\n}\n"