export default "/*--------------------------------*- Choupo -*-----------------------*\\\n  Component: octamethylcyclotetrasiloxane  (C8H24O4Si4, CAS 556-67-2)\n  PROPOSAL TIER -- UNVERIFIED.  Imported from CoolProp 7.2.0 (MIT);\n  pure-fluid properties from the published reference EOS below.\n  Reference EOS: Thol-THESIS-2015\n  NOTE: formation properties (dHf, s_298) and group decompositions\n  are NOT provided by CoolProp -> omitted here (a gap, not fabricated).\n\\*---------------------------------------------------------------------------*/\n\nname        octamethylcyclotetrasiloxane;\nformula     C8H24O4Si4;\nCAS         556-67-2;\n\nMW          296.6158;        // kg/kmol  [CoolProp]\nTc          586.5000;        // K        [CoolProp EOS]\nPc          13.47215;        // bar      [CoolProp EOS]\nomega       0.59812;        // [-]      [CoolProp EOS]\nTb          448.8906;        // K  normal boiling [CoolProp]\nHvapTb      38820.7;        // J/mol  at Tb     [CoolProp]\nVliq        3.1199e-04;        // m3/mol @298K     [CoolProp]\n\nvaporPressure\n{\n    model         Antoine;\n    // log10(Psat [bar]) = A - B / (T[K] + C)   -- fitted to CoolProp EOS\n    coefficients  (4.01468   1446.27   -88.1603);\n    Trange        (290.75  574.77);\n}\n\nidealGasHeatCapacity\n{\n    model         polynomial;\n    // Cp [J/(mol.K)] = a0 + a1 T + a2 T^2 + a3 T^3   -- fitted to CoolProp cp0\n    coefficients  (187.454  0.627516  0.000315233  -4.07309e-07);\n    Trange        (200  1000);\n}\n\nliquidHeatCapacity\n{\n    model         polynomial;\n    // Cp_liq [J/(mol.K)]   -- fitted to CoolProp saturated-liquid cp\n    coefficients  (556.074  -1.117  0.003858  -2.65386e-06);\n    Trange        (295  449);\n}\n\nsublimation\n{\n    tripleT   290.2500;        // K   [CoolProp]\n    tripleP   73.0661;        // Pa  [CoolProp]\n    // Hfus / Hsub absent: CoolProp models no solid phase.  The\n    // sublimation curve stays undrawn until measured Hsub lands.\n}\n\nprovenance\n{\n    constants      \"CoolProp 7.2.0 -- Thol-THESIS-2015\";\n    vaporPressure  \"Antoine fitted to CoolProp EOS saturation, AAD 0.55%\";\n    idealGasCp     \"polynomial fitted to CoolProp cp0, maxerr 3.31%\";\n    liquidCp       \"polynomial fitted to CoolProp sat-liquid cp, maxerr 0.02%\";\n    triplePoint    \"CoolProp reference EOS triple-point T,P\";\n}\n"