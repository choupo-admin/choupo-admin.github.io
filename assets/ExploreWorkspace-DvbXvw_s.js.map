export default "/*--------------------------------*- Choupo -*-----------------------*\\\n  Component: dodecamethylcyclohexasiloxane  (C12H36O6Si6, CAS 540-97-6)\n  PROPOSAL TIER -- UNVERIFIED.  Imported from CoolProp 7.2.0 (MIT);\n  pure-fluid properties from the published reference EOS below.\n  Reference EOS: Colonna-FPE-2008\n  NOTE: formation properties (dHf, s_298) and group decompositions\n  are NOT provided by CoolProp -> omitted here (a gap, not fabricated).\n\\*---------------------------------------------------------------------------*/\n\nname        dodecamethylcyclohexasiloxane;\nformula     C12H36O6Si6;\nCAS         540-97-6;\n\nMW          444.9240;        // kg/kmol  [CoolProp]\nTc          645.7583;        // K        [CoolProp EOS]\nPc          9.61416;        // bar      [CoolProp EOS]\nomega       0.73600;        // [-]      [CoolProp EOS]\nTb          518.1100;        // K  normal boiling [CoolProp]\nHvapTb      44069.4;        // J/mol  at Tb     [CoolProp]\nVliq        4.5953e-04;        // m3/mol @298K     [CoolProp]\n\nvaporPressure\n{\n    model         Antoine;\n    // log10(Psat [bar]) = A - B / (T[K] + C)   -- fitted to CoolProp EOS\n    coefficients  (4.15078   1751.58   -95.3941);\n    Trange        (290.59  632.84);\n}\n\nidealGasHeatCapacity\n{\n    model         polynomial;\n    // Cp [J/(mol.K)] = a0 + a1 T + a2 T^2 + a3 T^3   -- fitted to CoolProp cp0\n    coefficients  (136.451  1.75019  -0.00109067  2.83929e-07);\n    Trange        (255  1000);\n}\n\nliquidHeatCapacity\n{\n    model         polynomial;\n    // Cp_liq [J/(mol.K)]   -- fitted to CoolProp saturated-liquid cp\n    coefficients  (482.815  0.555259  0.000672179  -3.54642e-07);\n    Trange        (323  518);\n}\n\nsublimation\n{\n    tripleT   270.2000;        // K   [CoolProp]\n    tripleP   0.1598;        // Pa  [CoolProp]\n    // Hfus / Hsub absent: CoolProp models no solid phase.  The\n    // sublimation curve stays undrawn until measured Hsub lands.\n}\n\nprovenance\n{\n    constants      \"CoolProp 7.2.0 -- Colonna-FPE-2008\";\n    vaporPressure  \"Antoine fitted to CoolProp EOS saturation, AAD 1.21%\";\n    idealGasCp     \"polynomial fitted to CoolProp cp0, maxerr 1.27%\";\n    liquidCp       \"polynomial fitted to CoolProp sat-liquid cp, maxerr 0.07%\";\n    triplePoint    \"CoolProp reference EOS triple-point T,P\";\n}\n"