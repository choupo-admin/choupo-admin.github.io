export default "/*---------------------------------------------------------------------------*\\\n  Wilson binary interaction parameters --- ethanol(1) + water(2)\n\\*---------------------------------------------------------------------------*/\n\ncomponents  ( ethanol  water );\nmodel       Wilson;\n\nparameters\n{\n    i           ethanol;\n    j           water;\n    A_ij        1157.95;             // J/mol\n    A_ji        4081.65;             // J/mol\n}\n\nprovenance\n{\n    source        literature;\n    citation      \"DECHEMA Chemistry Data Series Vol. I, regressed against atmospheric VLE\";\n    fitData       \"<not refit>\";\n    fitDate       \"<literature>\";\n    algorithm     \"<not reported in source>\";\n    chi2          \"<not reported>\";\n    nDataPoints   0;\n    validityRange { Tmin 298.0; Tmax 373.0; }\n    author        \"Curated from DECHEMA by V. Geraldes, 2026\";\n    notes         \"Standard Wilson set for ethanol-water; comparable accuracy to NRTL near the azeotrope. Requires V_liq per component (from data/standards/components/<name>.dat).\";\n}\n"