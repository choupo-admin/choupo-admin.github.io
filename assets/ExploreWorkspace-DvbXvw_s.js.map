l  ideal-gas [origin=estimated method=Joback uncertainty=~9kJ/mol]\n    dGf_298   -519370;      // J/mol  ideal-gas [Joback]\n    s_298     324.483;      // J/(mol*K) third-law [DERIVED: (dHf-dGf)/T + CODATA element S; ~25 J/mol/K; biased ~R*ln(sigma) for symmetric species]\n    phase     gas;\n}\n\ngroups { joback ( { group C; count 1; } { group eCH2; count 1; } { group eCH; count 1; } { group F; count 3; } ); }\n\nprovenance\n{\n    constants      \"CoolProp 7.2.0 -- Akasaka-JCED-2019\";\n    vaporPressure  \"Antoine fitted to CoolProp EOS saturation, AAD 0.39%\";\n    idealGasCp     \"polynomial fitted to CoolProp cp0, maxerr 1.40%\";\n    liquidCp       \"polynomial fitted to CoolProp sat-liquid cp, maxerr 0.00%\";\n    triplePoint    \"CoolProp reference EOS triple-point T,P\";\n    preserved      \"from prior proposal (NOT CoolProp): gibbsFormation, groups\";\n}\n"