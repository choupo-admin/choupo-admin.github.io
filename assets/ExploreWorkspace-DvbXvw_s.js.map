export default "// HELD (Wave-2 REPLACE merge): grafts the prior standard's\n// formation/transport over CoolProp constants. NOT promotable\n// until its inherited gibbs is re-sourced clean. Per-file GO only.\n/*--------------------------------*- Choupo -*-----------------------*\\\n  Component: NH3  (H3N1, CAS 7664-41-7)\n  PROPOSAL TIER -- UNVERIFIED.  Imported from CoolProp 7.2.0 (MIT);\n  pure-fluid properties from the published reference EOS below.\n  Reference EOS: Gao-JPCRD-2020\n  NOTE: formation properties (dHf, s_298) and group decompositions\n  are NOT provided by CoolProp -> omitted here (a gap, not fabricated).\n\\*---------------------------------------------------------------------------*/\n\nname        NH3;\nformula     H3N1;\nCAS         7664-41-7;\n\nMW          17.0305;        // kg/kmol  [CoolProp]\nTc          405.5600;        // K        [CoolProp EOS]\nPc          113.63391;        // bar      [CoolProp EOS]\nomega       0.25569;        // [-]      [CoolProp EOS]\nTb          239.8343;        // K  normal boiling [CoolProp]\nHvapTb      23326.2;        // J/mol  at Tb     [CoolProp]\nVliq        2.8245e-05;        // m3/mol @298K     [CoolProp]\n\nvaporPressure\n{\n    model         Antoine;\n    // log10(Psat [bar]) = A - B / (T[K] + C)   -- fitted to CoolProp EOS\n    coefficients  (4.69164   1009.23   -24.5909);\n    Trange        (196.00  397.45);\n}\n\nidealGasHeatCapacity\n{\n    model         polynomial;\n    // Cp [J/(mol.K)] = a0 + a1 T + a2 T^2 + a3 T^3   -- fitted to CoolProp cp0\n    coefficients  (29.487  0.012984  3.25013e-05  -1.86061e-08);\n    Trange        (200  1000);\n}\n\nliquidHeatCapacity\n{\n    model         polynomial;\n    // Cp_liq [J/(mol.K)]   -- fitted to CoolProp saturated-liquid cp\n    coefficients  (114.218  -0.654028  0.00320304  -4.7521e-06);\n    Trange        (203  240);\n}\n\nsublimation\n{\n    tripleT   195.4950;        // K   [CoolProp]\n    tripleP   6055.8136;        // Pa  [CoolProp]\n    // Hfus / Hsub absent: CoolProp models no solid phase.  The\n    // sublimation curve stays undrawn until measured Hsub lands.\n}\n\ngibbsFormation\n{\n    dHf_298   -45939.7;        // J/mol  ideal-gas [origin=measured method=NASA-TM4513]\n    s_298     192.77;        // J/(mol.K) third-law absolute [NASA-TM4513]\n    phase     gas;\n}\n           liquidViscosity -- Engineering Toolbox saturated-liquid table.\n\\*---------------------------------------------------------------------------*/\n\nname        NH3;\nformula     NH3;\nCAS         7664-41-7;\n\nMW          17.030;            // kg/kmol\nTc          405.40;             // K\nPc          113.59;             // bar\nomega       0.252;              // [-]\nTb          239.82;             // K\nHvapTb      23330;              // J/mol\nVliq        2.50e-5;            // m^3/mol\nrole        solute;        // soluble gas: Henry K = H(T)/P (solvent water)\n\ngibbsFormation\n{\n    dHf_298    -45940.0;        // J/mol  -- ideal-gas reference\n    s_298      192.77;          // J/(mol·K)\n    phase     gas;            // ideal-gas Hf reference ([prior-standard]/JANAF convention)\n}\n\nprovenance\n{\n    constants      \"CoolProp 7.2.0 -- Gao-JPCRD-2020\";\n    vaporPressure  \"Antoine fitted to CoolProp EOS saturation, AAD 0.54%\";\n    idealGasCp     \"polynomial fitted to CoolProp cp0, maxerr 1.06%\";\n    liquidCp       \"polynomial fitted to CoolProp sat-liquid cp, maxerr 0.01%\";\n    triplePoint    \"CoolProp reference EOS triple-point T,P\";\n    inherited      \"gibbs/groups/transport grafted from prior standard (orig. attrib. = excluded aggregators (see COOLPROP-REPLACE-MERGE.md) -> re-source pending); CoolProp supplies constants/VP/Cp/triple\";\n    gibbsFormation \"NASA TM-4513 (McBride-Gordon-Reno 1993), H0/S0(298.15) from NASA-7 poly\";\n}\n"