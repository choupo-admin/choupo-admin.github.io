export default "// ============================================================\n//  PROPOSAL -- review before promoting to data/standards/\n//  name        1Butene\n//  CAS 106-98-9   CoolProp fluid: 1-Butene\n//  provenance  CoolProp 7.2.0 reference EOS (scalars + Psat/Cp fitted to it)\n//  reference   Lemmon-FPE-2005\n//  license     scalars + Psat = OPEN (CoolProp-MIT / corr-states); Cp/formation stripped for copyright -- student supplies\n//  formation   Hfg/S0g via chemicals (open methods), by CAS\n//  Antoine fit RMS(log10 bar) = 0.0004 over 189-280 K\n//  status      UNVERIFIED PROPOSAL -- review every value before promoting\n//  generated   2026-06-07 by choupoProps CoolProp ingestion\n// ============================================================\n\nname        butene1;\nMW          56.1063;        // kg/kmol\nTc          419.29;        // K\nPc          40.0572;        // bar\nomega       0.191861;        // [-]\nTb          266.844;        // K  normal boiling point\nHvapTb      22006.1;        // J/mol latent heat at Tb\nVliq        9.53896e-05;        // m^3/mol liquid molar volume\n// gibbsFormation -- dHf below; s_298 (absolute entropy) has NO open source.\n// Supply s_298 (third-law) + uncomment to enable energy balances:\n// gibbsFormation\n// {\n//     dHf_298   FILL;   // value removed (excluded source); student supplies, cite primary\n//     s_298     ?;             // J/(mol*K) -- FILL\n//     phase     gas;\n// }\nvaporPressure\n{\n    model         Antoine;\n    coefficients  (3.98749   934.943   -32.039);\n    Trange        (188.7  280.2);\n}\nidealGasHeatCapacity\n{\n    model         polynomial;\n    coefficients  (3.66226   0.324253   -0.000160251   2.91048e-08);\n    Trange        (200  1500);\n}\n\n// --- energy block: ESTIMATED (MIT-panel policy 2026-06-07), review before reaction-critical use ---\ngibbsFormation\n{\n    dHf_298   -460;      // J/mol  ideal-gas [origin=estimated method=Joback uncertainty=~9kJ/mol]\n    dGf_298   70640;      // J/mol  ideal-gas [Joback]\n    s_298     307.209;      // J/(mol*K) third-law [DERIVED: (dHf-dGf)/T + CODATA element S; ~25 J/mol/K; biased ~R*ln(sigma) for symmetric species]\n    phase     gas;\n}\n\n\n// Molecular group decomposition (the curation recipe this estimate was built\n// from).  Joback groups; re-run reproduces the estimate.  Method-keyed.\ngroups { joback ( { group CH3; count 1; } { group CH2; count 1; } { group eCH2; count 1; } { group eCH; count 1; } ); }\n\n// --- review status (machine-readable; data/proposed UNVERIFIED tier) ----------\n//  This file lives in data/proposed/ (NOT the verified data/standards/ tree).\n//  A student must REVIEW the values and PROMOTE it before they are trusted.\nprovenance\n{\n    status  \"UNVERIFIED ESTIMATE -- student-review pending (data/proposed tier)\";\n    review  { state pending; reviewer student; }\n}\n"