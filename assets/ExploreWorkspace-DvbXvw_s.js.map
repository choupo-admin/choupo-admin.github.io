export default "/*--------------------------------*- Choupo -*-----------------------*\\\n  Component: R23  (C1F3H1, CAS 75-46-7)\n  PROPOSAL TIER -- UNVERIFIED.  Imported from CoolProp 7.2.0 (MIT);\n  pure-fluid properties from the published reference EOS below.\n  Reference EOS: Penoncello-JPCRD-2003\n  NOTE: formation properties (dHf, s_298) and group decompositions\n  are NOT provided by CoolProp -> omitted here (a gap, not fabricated).\n\\*---------------------------------------------------------------------------*/\n\nname        R23;\nformula     C1F3H1;\nCAS         75-46-7;\n\nMW          70.0139;        // kg/kmol  [CoolProp]\nTc          299.2930;        // K        [CoolProp EOS]\nPc          48.31745;        // bar      [CoolProp EOS]\nomega       0.26296;        // [-]      [CoolProp EOS]\nTb          191.1321;        // K  normal boiling [CoolProp]\nHvapTb      16758.7;        // J/mol  at Tb     [CoolProp]\nVliq        1.0295e-04;        // m3/mol @298K     [CoolProp]\n\nvaporPressure\n{\n    model         Antoine;\n    // log10(Psat [bar]) = A - B / (T[K] + C)   -- fitted to CoolProp EOS\n    coefficients  (4.27879   724.797   -21.6031);\n    Trange        (134.68  293.31);\n}\n\nidealGasHeatCapacity\n{\n    model         polynomial;\n    // Cp [J/(mol.K)] = a0 + a1 T + a2 T^2 + a3 T^3   -- fitted to CoolProp cp0\n    coefficients  (13.2938  0.154851  -9.59388e-05  1.85118e-08);\n    Trange        (200  1000);\n}\n\nliquidHeatCapacity\n{\n    model         polynomial;\n    // Cp_liq [J/(mol.K)]   -- fitted to CoolProp saturated-liquid cp\n    coefficients  (68.9032  0.342392  -0.00276086  7.61235e-06);\n    Trange        (150  191);\n}\n\nsublimation\n{\n    tripleT   118.0200;        // K   [CoolProp]\n    tripleP   58.0410;        // Pa  [CoolProp]\n    // Hfus / Hsub absent: CoolProp models no solid phase.  The\n    // sublimation curve stays undrawn until measured Hsub lands.\n}\n\ngibbsFormation\n{\n    dHf_298   -657580;      // J/mol  ideal-gas [origin=estimated method=Joback uncertainty=~9kJ/mol]\n    dGf_298   -629330;      // J/mol  ideal-gas [Joback]\n    s_298     280.529;      // J/(mol*K) third-law [DERIVED: (dHf-dGf)/T + CODATA element S; ~25 J/mol/K; biased ~R*ln(sigma) for symmetric species]\n    phase     gas;\n}\n\ngroups { joback ( { group CH; count 1; } { group F; count 3; } ); }\n\nprovenance\n{\n    constants      \"CoolProp 7.2.0 -- Penoncello-JPCRD-2003\";\n    vaporPressure  \"Antoine fitted to CoolProp EOS saturation, AAD 0.61%\";\n    idealGasCp     \"polynomial fitted to CoolProp cp0, maxerr 1.58%\";\n    liquidCp       \"polynomial fitted to CoolProp sat-liquid cp, maxerr 0.00%\";\n    triplePoint    \"CoolProp reference EOS triple-point T,P\";\n    preserved      \"from prior proposal (NOT CoolProp): gibbsFormation, groups\";\n}\n"